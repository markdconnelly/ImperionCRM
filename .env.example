# Copy to .env.local and fill with real values. .env.local is gitignored — never commit secrets.

# Entra ID (OAuth/OIDC) — sole identity provider. Do not introduce third-party IdPs.
# Certificate-based client authentication (no client secret).
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
# Provide the PFX one of two ways: a local file path (dev) OR base64 (App Service).
AZURE_AD_CERT_PFX_PATH=        # local path to the private-key PFX (NOT in the repo)
AZURE_AD_CERT_PFX_BASE64=      # base64 of the PFX, for hosts without a file path
AZURE_AD_CERT_PFX_PASSWORD=    # password protecting the PFX

# Auth.js session encryption key — generate a crypto-random value (e.g. `npx auth secret`)
AUTH_SECRET=
AUTH_URL=http://localhost:3000   # deployed: https://imperioncrm.azurewebsites.net

# Break-glass emergency access (ADR-0008) — SSO bypass via /break-glass.
# Disabled unless both are set. Hash: lowercase hex SHA-256 of the password.
BREAKGLASS_USERNAME=
BREAKGLASS_PASSWORD_HASH=

# PostgreSQL + pgvector (system of record, embedding store, agent memory).
# Local dev: a connection string with a password.
DATABASE_URL=postgres://user:password@localhost:5432/imperioncrm
# Deployed (Azure): managed-identity mode — no password. The app fetches an Entra
# token from the user-assigned identity. Set these instead of DATABASE_URL.
PGHOST=                          # e.g. imperioncrm-pg-prd.postgres.database.azure.com
PGPORT=5432
PGDATABASE=imperioncrm
PGUSER=                          # the managed identity's DB role name
PGSSLMODE=require
AZURE_MANAGED_IDENTITY_CLIENT_ID=   # clientId of the user-assigned managed identity

# External functions/APIs (ADR-0018). The GUI calls these; until a URL is set the
# matching service client fails closed. Hosted on separate objects, not in this repo.
AGENT_SERVICE_URL=
INTEGRATION_SERVICE_URL=
ENRICHMENT_SERVICE_URL=
COMMS_SERVICE_URL=
CAMPAIGN_SERVICE_URL=
BOARD_SERVICE_URL=

# Provider-agnostic AI model-routing layer (used by the external agent service)
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
