# Entra ID (OAuth/OIDC) — sole identity provider. Do not introduce third-party IdPs.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# PostgreSQL + pgvector (system of record, embedding store, agent memory)
DATABASE_URL=postgres://user:password@localhost:5432/meridian

# Provider-agnostic AI model-routing layer (runtime AI the app calls)
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
