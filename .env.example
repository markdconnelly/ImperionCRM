# Copy to .env.local and fill with real values. .env.local is gitignored — never commit secrets.

# Entra ID (OAuth/OIDC) — sole identity provider. Do not introduce third-party IdPs.
# Certificate-based client authentication (no client secret).
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
# Provide the PFX one of two ways: a local file path (dev) OR base64 (App Service).
AZURE_AD_CERT_PFX_PATH=        # local path to the private-key PFX (NOT in the repo)
AZURE_AD_CERT_PFX_BASE64=      # base64 of the PFX, for hosts without a file path
AZURE_AD_CERT_PFX_PASSWORD=    # password protecting the PFX

# Auth.js session encryption key — generate a crypto-random value (e.g. `npx auth secret`)
AUTH_SECRET=
AUTH_URL=http://localhost:3000   # deployed: https://os.imperionllc.com

# Public origin override (consumed by src/lib/integrations/request-origin.ts).
# Highest-precedence source for the app's public URL when building OAuth callback
# and post-auth redirects. Set in deployed environments so every redirect stays on
# the custom domain instead of drifting to the *.azurewebsites.net host.
# deployed: https://os.imperionllc.com  (leave unset for local dev)
APP_PUBLIC_ORIGIN=

# Break-glass emergency access (ADR-0008) — SSO bypass via /break-glass.
# Disabled unless both are set. Hash: lowercase hex SHA-256 of the password.
BREAKGLASS_USERNAME=
BREAKGLASS_PASSWORD_HASH=

# Role mapping (ADR-0030). Maps Entra security-group OBJECT IDs (GUIDs) to app
# roles. Only needed when the app registration emits the `groups` claim; if it
# emits App-Role strings instead, these can stay blank. Unset ⇒ users default to
# the most-restricted `support` role.
ENTRA_GROUP_ADMINS=              # object id of Application.ImperionCRM.Admins
ENTRA_GROUP_FINANCE=             # object id of Application.ImperionCRM.Finance
ENTRA_GROUP_PROJECTMANAGER=      # object id of Application.ImperionCRM.ProjectManager
ENTRA_GROUP_SALES=               # object id of Application.ImperionCRM.Sales
ENTRA_GROUP_SUPPORT=             # object id of Application.ImperionCRM.Support
# Local-only override to preview a restricted GUI before the claim is live
# (e.g. DEV_ROLE=admin | sales | support). Leave unset in deployed environments.
DEV_ROLE=
# Bootstrap escape hatch (ADR-0045). Leave unset/false → the app FAILS CLOSED: a
# user with no recognized role claim becomes `support`. Set to `true` ONLY as a
# temporary measure while Entra App Roles are being assigned, to let a no-claim
# user act as `admin`. Prefer break-glass over this flag. Never `true` in prod.
RBAC_FAIL_OPEN_ADMIN=

# PostgreSQL + pgvector (system of record, embedding store, agent memory).
# Local dev: a connection string with a password.
DATABASE_URL=postgres://user:password@localhost:5432/imperioncrm
# Deployed (Azure): managed-identity mode — no password. The app fetches an Entra
# token from the user-assigned identity. Set these instead of DATABASE_URL.
PGHOST=                          # e.g. imperioncrm-pg-prd-cus.postgres.database.azure.com
PGPORT=5432
PGDATABASE=imperioncrm
PGUSER=                          # the managed identity's DB role name
PGSSLMODE=require
AZURE_MANAGED_IDENTITY_CLIENT_ID=   # clientId of the user-assigned managed identity

# External functions/APIs (ADR-0018). The GUI calls these; until a URL is set the
# matching service client fails closed. Hosted on separate objects, not in this repo.
AGENT_SERVICE_URL=
INTEGRATION_SERVICE_URL=
ENRICHMENT_SERVICE_URL=
COMMS_SERVICE_URL=
CAMPAIGN_SERVICE_URL=
BOARD_SERVICE_URL=
# Cloud data pipeline (pipeline ADR-0011) — the "Refresh now" on-demand sync endpoint,
# e.g. https://imperioncrmpipeline.azurewebsites.net/api . PIPELINE_SERVICE_AUDIENCE
# stays unset until the pipeline gets Easy Auth (webhook path exclusions needed first).
PIPELINE_SERVICE_URL=
PIPELINE_SERVICE_AUDIENCE=

# AI: NONE in the front end (ADR-0043). The stack is settled (backend ADR-0034):
# Claude (generation) + Voyage voyage-3-large @ 1024 (embeddings), configured ON THE
# BACKEND via Key Vault secret names (ANTHROPIC_API_KEY_SECRET / VOYAGE_API_KEY_SECRET).
# The front end calls the backend's APIs; it never holds an AI key.
