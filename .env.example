# Copy to .env.local and fill with real values. .env.local is gitignored — never commit secrets.

# Entra ID (OAuth/OIDC) — sole identity provider. Do not introduce third-party IdPs.
# Certificate-based client authentication (no client secret).
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CERT_PFX_PATH=        # local path to the private-key PFX (NOT in the repo)
AZURE_AD_CERT_PFX_PASSWORD=    # password protecting the PFX

# Auth.js session encryption key — generate a crypto-random value (e.g. `npx auth secret`)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# PostgreSQL + pgvector (system of record, embedding store, agent memory)
DATABASE_URL=postgres://user:password@localhost:5432/meridian

# Provider-agnostic AI model-routing layer (runtime AI the app calls)
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
